{
  "name": "@expo-state-mcp/server",
  "version": "0.1.1",
  "description": "MCP server (stdio) that proxies to @expo-state-mcp/bridge over HTTP",
  "type": "module",
  "bin": {
    "expo-state-mcp": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/add-shebang.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "mcp",
    "sqlite",
    "zustand",
    "cursor"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitrionbv/expo-state-mcp.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/vitrionbv/expo-state-mcp/issues"
  },
  "homepage": "https://github.com/vitrionbv/expo-state-mcp#readme"
}
