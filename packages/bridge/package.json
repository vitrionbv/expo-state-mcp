{
  "name": "@expo-state-mcp/bridge",
  "version": "0.1.1",
  "description": "In-app HTTP bridge for Expo SQLite + Zustand, dev-only, for use with @expo-state-mcp/server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "echo \"no lint yet\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "sqlite",
    "zustand",
    "mcp",
    "devtools"
  ],
  "dependencies": {
    "react-native-tcp-socket": "^6.4.1"
  },
  "peerDependencies": {
    "expo-sqlite": ">=14.0.0",
    "react": "*",
    "react-native": "*",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-community/netinfo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "expo-sqlite": "~16.0.10",
    "typescript": "~5.9.2",
    "zustand": "^5.0.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitrionbv/expo-state-mcp.git",
    "directory": "packages/bridge"
  },
  "bugs": {
    "url": "https://github.com/vitrionbv/expo-state-mcp/issues"
  },
  "homepage": "https://github.com/vitrionbv/expo-state-mcp#readme"
}
