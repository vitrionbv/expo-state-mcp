{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/app",
    "rootDir": "src/app",
    "noEmitOnError": true
  },
  "include": ["src/app/**/*"]
}
