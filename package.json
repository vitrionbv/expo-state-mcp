{
  "name": "@vitrion/expo-state-mcp",
  "version": "1.1.1",
  "description": "MCP (stdio) + in-app HTTP bridge for Expo SQLite and Zustand — one package, dev-only",
  "type": "module",
  "main": "./dist/cli/cli.js",
  "types": "./dist/app/index.d.ts",
  "bin": {
    "expo-state-mcp": "dist/cli/cli.js"
  },
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/app/index.d.ts",
        "default": "./dist/app/index.js"
      },
      "types": "./dist/cli/cli.d.ts",
      "default": "./dist/cli/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "yarn build:app && yarn build:cli && node ./scripts/add-shebang.mjs",
    "build:app": "tsc -p tsconfig.app.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.cli.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "yarn typecheck && yarn lint && yarn test && yarn build",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "mcp",
    "sqlite",
    "zustand",
    "cursor"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "buffer": "^6.0.3",
    "react-native-tcp-socket": "^6.4.1",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "expo-sqlite": ">=14.0.0",
    "react": "*",
    "react-native": "*",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "expo-sqlite": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "zustand": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "~19.1.0",
    "eslint": "^10.2.1",
    "expo-sqlite": "~16.0.10",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "zustand": "^5.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitrionbv/expo-state-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vitrionbv/expo-state-mcp/issues"
  },
  "homepage": "https://github.com/vitrionbv/expo-state-mcp#readme"
}
